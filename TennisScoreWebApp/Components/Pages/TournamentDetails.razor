@page "/tournaments/{TournamentId:guid}"
@using Microsoft.AspNetCore.SignalR
@using Microsoft.AspNetCore.SignalR.Client
@using TennisScoreWebApp.Infrastructure.ExternalServices.TennisScoreApi
@using TennisScoreWebApp.Services
@inject ITennisApiClient TennisApiClient
@inject HubService HubService
@inject NavigationManager Navigation
@inject IJSRuntime JS

@rendermode InteractiveServer

@if (Tournament == null)
{
    <p>Loading...</p>
}
else
{
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="mb-0">Tournament details</h2>
        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="GoBack">
            Back to tournaments
        </button>
    </div>

    <!-- Tournament info card -->
    <div class="card shadow-sm mb-4">
        <div class="card-body p-3">
            <div class="d-flex flex-column flex-md-row align-items-md-start justify-content-between gap-3">
                <div>
                    <h3 class="card-title mb-2">@Tournament.Name</h3>
                    <p class="mb-1"><strong>Location:</strong> @Tournament.Location</p>
                    <p class="mb-1"><strong>Surface:</strong> @Tournament.Surface</p>
                    <p class="mb-1"><strong>Dates:</strong> @($"{Tournament.StartDate:dd MMM yyyy} – {Tournament.EndDate:dd MMM yyyy}")</p>
                    <p class="mb-0"><strong>Matches:</strong> @Matches.Count</p>
                </div>
                <NavLink href=@($"/matches/create/{Tournament.Id}") class="btn btn-primary btn-sm">
                    New Match
                </NavLink>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }

    <style>
        .match-card {
            cursor: pointer;
            transition: border-color .15s ease, box-shadow .15s ease;
        }

        .match-card:hover,
        .match-card:focus {
            border-color: rgba(13, 110, 253, .35);
            box-shadow: 0 .125rem .375rem rgba(0, 0, 0, .12);
            outline: none;
        }

        .match-delete-button {
            opacity: .35;
            transform: scale(.72);
            transition: opacity .15s ease;
        }

        .match-card:hover .match-delete-button,
        .match-delete-button:focus {
            opacity: .65;
        }
    </style>

    <!-- Live scores -->
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-3">
        <h5 class="mb-0">Live scores</h5>
        @if (Matches.Any())
        {
            <div class="btn-group btn-group-sm" role="group" aria-label="Filter matches by status">
                @foreach (var filter in MatchStatusFilters)
                {
                    <button type="button"
                            class="btn @(SelectedStatusFilter == filter ? "btn-primary" : "btn-outline-primary")"
                            @onclick="() => SetStatusFilter(filter)">
                        @filter
                    </button>
                }
            </div>
        }
    </div>

    @if (!Matches.Any())
    {
        <p>No match in this tournament yet.</p>
    }
    else if (!FilteredMatches.Any())
    {
        <p>No matches for the selected status.</p>
    }
    else
    {
        <div class="row g-2">
            @foreach (var match in FilteredMatches.Take(ShowAll ? FilteredMatches.Count : 6))
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card shadow-sm match-card position-relative"
                         role="link"
                         tabindex="0"
                         @onclick="() => GoToMatch(match.Id)"
                         @onkeydown="args => HandleMatchCardKeyDown(args, match.Id)">
                        <button type="button"
                                class="btn-close match-delete-button position-absolute top-0 end-0 m-2"
                                aria-label="Delete match"
                                disabled="@(deletingMatchId == match.Id)"
                                @onclick:stopPropagation="true"
                                @onclick="() => DeleteMatch(match)">
                        </button>
                        <div class="card-body p-2 pe-4">
                            <div class="d-flex justify-content-start mb-1">
                                <span class="badge @GetStatusBadgeClass(match)">@GetMatchStatus(match)</span>
                            </div>
                            <table class="table table-sm table-borderless text-center mb-0 align-middle">
                                <tbody>
                                    <tr>
                                        <td class="text-start fw-bold">
                                            @match.Player1.LastName
                                            @if (match.ServingPlayerId == match.Player1.Id)
                                            {
                                                <span title="Serving"> 🎾</span>
                                            }
                                        </td>
                                        @foreach (var set in match.Sets)
                                        {
                                            <td>@GetSetCellScore(match, set, match.Player1.Id)</td>
                                        }
                                        @if (!match.IsCompleted)
                                        {
                                            <td class="fw-bold text-primary">
                                                @match.Player1.CurrentScore
                                            </td>
                                        }
                                    </tr>
                                    <tr>
                                        <td class="text-start fw-bold">
                                            @match.Player2.LastName
                                            @if (match.ServingPlayerId == match.Player2.Id)
                                            {
                                                <span title="Serving"> 🎾</span>
                                            }
                                        </td>
                                        @foreach (var set in match.Sets)
                                        {
                                            <td>@GetSetCellScore(match, set, match.Player2.Id)</td>
                                        }
                                        @if (!match.IsCompleted)
                                        {
                                            <td class="fw-bold text-primary">
                                                @match.Player2.CurrentScore
                                            </td>
                                        }
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (FilteredMatches.Count > 6)
    {
        <div class="text-center mt-3">
            <button class="btn btn-outline-primary btn-sm" @onclick="ToggleShowAll">
                @(ShowAll ? "See less" : "See more")
            </button>
        </div>
    }
}

@code {
    [Parameter] public Guid TournamentId { get; set; }
    private TournamentDto? Tournament { get; set; }
    private bool ShowAll = false;
    private Guid? deletingMatchId;
    private string? errorMessage;
    private string SelectedStatusFilter = "All";
    private List<MatchDetailsDto> Matches => Tournament?.Matches?.ToList() ?? new List<MatchDetailsDto>();
    private List<MatchDetailsDto> FilteredMatches => Matches
        .Where(match => SelectedStatusFilter == "All" || GetMatchStatus(match) == SelectedStatusFilter)
        .ToList();
    private static readonly string[] MatchStatusFilters = ["All", "Not started", "Live", "Finished"];

    protected override async Task OnInitializedAsync()
    {
        Tournament = await TennisApiClient.TournamentsGETAsync(TournamentId);

        //SignalR connection setup
        await HubService.StartAsync(tournamentId: TournamentId);
        HubService.OnMatchUpdated += UpdateMatch;
    }

    private void UpdateMatch(MatchDetailsDto updatedMatch)
    {
        InvokeAsync(() =>
        {
            var existing = Tournament?.Matches.FirstOrDefault(m => m.Id == updatedMatch.Id);
            if (existing != null)
            {
                existing.Player1.CurrentScore = updatedMatch.Player1.CurrentScore;
                existing.Player2.CurrentScore = updatedMatch.Player2.CurrentScore;
                existing.Sets = updatedMatch.Sets;
                existing.ServingPlayerId = updatedMatch.ServingPlayerId;
                existing.EndTime = updatedMatch.EndTime;
                existing.IsCompleted = updatedMatch.IsCompleted;
                existing.Score = updatedMatch.Score;
                existing.WinnerFirstName = updatedMatch.WinnerFirstName;
                existing.WinnerLastName = updatedMatch.WinnerLastName;
                StateHasChanged();
            }
        });
    }

    public async ValueTask DisposeAsync()
    {
        HubService.OnMatchUpdated -= UpdateMatch;
    }

    private static string GetPlayerName(PlayerDto player)
        => $"{player.FirstName} {player.LastName}".Trim();

    private static string GetMatchStatus(MatchDetailsDto match)
    {
        if (match.IsCompleted)
            return "Finished";

        return match.Sets?.Any() == true ? "Live" : "Not started";
    }

    private static string GetStatusBadgeClass(MatchDetailsDto match)
        => GetMatchStatus(match) switch
        {
            "Finished" => "text-bg-success",
            "Live" => "text-bg-primary",
            _ => "text-bg-secondary"
        };

    private void SetStatusFilter(string filter)
    {
        SelectedStatusFilter = filter;
        ShowAll = false;
    }

    private static string GetSetCellScore(MatchDetailsDto match, SetScoreDto set, Guid playerId)
    {
        var isPlayer1 = match.Player1.Id == playerId;
        var games = isPlayer1 ? set.Player1Games : set.Player2Games;
        var otherGames = isPlayer1 ? set.Player2Games : set.Player1Games;
        var tieBreakPoints = isPlayer1 ? set.Player1TieBreakPoints : set.Player2TieBreakPoints;

        if (set.IsSuperTieBreak && tieBreakPoints.HasValue)
            return tieBreakPoints.Value.ToString();

        if (set.IsTieBreak && games < otherGames && tieBreakPoints.HasValue)
            return $"{games}({tieBreakPoints})";

        return games.ToString();
    }

    private void GoToMatch(Guid matchId)
    {
        Navigation.NavigateTo($"/match/{matchId}");
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/tournaments");
    }

    private void HandleMatchCardKeyDown(KeyboardEventArgs args, Guid matchId)
    {
        if (args.Key is "Enter" or " ")
        {
            GoToMatch(matchId);
        }
    }

    private async Task DeleteMatch(MatchDetailsDto match)
    {
        errorMessage = null;

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Delete match {GetPlayerName(match.Player1)} vs {GetPlayerName(match.Player2)}?");

        if (!confirmed)
        {
            return;
        }

        deletingMatchId = match.Id;

        try
        {
            var deleted = await TennisApiClient.MatchesDELETEAsync(match.Id);
            if (deleted)
            {
                Tournament?.Matches.Remove(match);
            }
            else
            {
                errorMessage = "The match could not be deleted.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to delete match: {ex.Message}";
        }
        finally
        {
            deletingMatchId = null;
        }
    }

    private void ToggleShowAll() => ShowAll = !ShowAll;
}
