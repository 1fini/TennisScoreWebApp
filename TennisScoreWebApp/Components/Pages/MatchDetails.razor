@page "/match/{MatchId:guid}"
@using TennisScoreWebApp.Infrastructure.ExternalServices.TennisScoreApi
@using TennisScoreWebApp.Services
@inject NavigationManager Navigation
@inject ITennisApiClient TennisApiClient
@inject HubService HubService

@rendermode InteractiveServer

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="mb-0">Match details</h2>
    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="GoBack">
        Back to tournament
    </button>
</div>

@if (Match == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h3 class="card-title mb-3">@Match.Player1.LastName vs @Match.Player2.LastName</h3>
            <p class="card-text mb-2"><strong>Tournament:</strong> @Match.TournamentName</p>
            <p class="card-text mb-3"><strong>Date:</strong> @($"{Match.StartTime:dd MMM yyyy}")</p>
            
            <h5>Set score</h5>
            @if (Match.Sets != null && Match.Sets.Any())
            {
                <table class="table table-striped table-bordered w-auto text-center align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Player</th>
                            <th>Points</th>
                            @for (int i = 0; i < Match.Sets.Count; i++)
                            {
                                <th>Set @(i + 1)</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="text-start fw-bold">
                                @Match.Player1.LastName
                                @if (@Match.ServingPlayerId == @Match.Player1.Id)
                                {
                                    <span title="Serving" class="ms-1">🎾</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-warning text-dark fs-6 px-3">
                                    @(Match.Player1.CurrentScore ?? "0")
                                </span>
                            </td>
                            @foreach (var set in Match.Sets)
                            {
                                <td>@set.Player1Games</td>
                            }
                        </tr>
                        <tr>
                            <td class="text-start fw-bold">
                                @Match.Player2.LastName
                                @if (@Match.ServingPlayerId == @Match.Player2.Id)
                                {
                                    <span title="Serving" class="ms-1">🎾</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-warning text-dark fs-6 px-3">
                                    @(Match.Player2.CurrentScore ?? "0")
                                </span>
                            </td>
                            @foreach (var set in Match.Sets)
                            {
                                <td>@set.Player2Games</td>
                            }
                        </tr>
                    </tbody>
                </table>

            }
            else
            {
                <p>Match not started yet.</p>
            }
        </div>
    </div>

    <style>
        .point-actions-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: .5rem;
        }

        .point-action-button {
            min-height: 2.5rem;
            text-align: left;
        }

        .point-action-section + .point-action-section {
            border-top: 1px solid var(--bs-border-color);
            margin-top: 1rem;
            padding-top: 1rem;
        }

        .point-action-section-title {
            font-size: .8rem;
            font-weight: 700;
            letter-spacing: .02em;
            text-transform: uppercase;
        }

        @@media (max-width: 576px) {
            .point-actions-grid {
                grid-template-columns: 1fr;
            }

            .point-action-button {
                text-align: center;
            }
        }
    </style>

    <h4 class="mb-3">Add a point</h4>
    <div class="row g-3 mb-4">
        @foreach (var player in new[] { Match.Player1, Match.Player2 })
        {
            <div class="col-12 col-lg-6">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <div>
                                <h5 class="mb-0">@GetPlayerName(player)</h5>
                                <small class="text-muted">Record an event by this player</small>
                            </div>
                            @if (Match.ServingPlayerId == player.Id)
                            {
                                <span class="badge bg-light text-dark border" title="Serving">Serving</span>
                            }
                        </div>

                        <div class="point-action-section">
                            <div class="point-action-section-title text-success mb-2">
                                Point won by @GetPlayerName(player)
                            </div>
                            <div class="point-actions-grid">
                                @foreach (var pointType in PointWonActions)
                                {
                                    <button type="button"
                                            class="btn @GetPointClass(pointType) point-action-button"
                                            @onclick="(() => AddPoint(player.Id, pointType))">
                                        @GetPointLabel(pointType)
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="point-action-section">
                            <div class="point-action-section-title text-danger mb-2">
                                Error by @GetPlayerName(player), point to @GetPlayerName(GetOpponent(player))
                            </div>
                            <div class="point-actions-grid">
                                @foreach (var pointType in OpponentPointActions)
                                {
                                    <button type="button"
                                            class="btn @GetPointClass(pointType) point-action-button"
                                            @onclick="(() => AddPoint(GetOpponent(player).Id, pointType))">
                                        @GetPointLabel(pointType)
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private static readonly PointType[] PointWonActions =
    [
        PointType.Ace,
        PointType.Winner
    ];

    private static readonly PointType[] OpponentPointActions =
    [
        PointType.ForcedError,
        PointType.UnforcedError,
        PointType.DoubleFault,
        PointType.TimeViolation
    ];

    [Parameter] public Guid MatchId { get; set; }
    private MatchDetailsDto? Match { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Match = await TennisApiClient.MatchesGETAsync(MatchId);

        // Hub connection
        await HubService.StartAsync(matchId: MatchId);

        // Subscribe to updates
        HubService.OnMatchUpdated += UpdateMatch;
    }

    private void UpdateMatch(MatchDetailsDto updatedMatch)
    {
        InvokeAsync(() =>
        {
            if (updatedMatch.Id == Match?.Id)
            {
                Match.Player1.CurrentScore = updatedMatch.Player1.CurrentScore;
                Match.Player2.CurrentScore = updatedMatch.Player2.CurrentScore;
                Match.Sets = updatedMatch.Sets;
                Match.ServingPlayerId = updatedMatch.ServingPlayerId;
                StateHasChanged();
            }
        });
    }

    private static string GetPlayerName(PlayerDto player)
        => $"{player.FirstName} {player.LastName}".Trim();

    private PlayerDto GetOpponent(PlayerDto player)
        => Match?.Player1.Id == player.Id ? Match.Player2 : Match?.Player1 ?? player;

    private static string GetPointLabel(PointType pointType)
        => pointType switch
        {
            PointType.Ace => "Ace",
            PointType.DoubleFault => "Double fault",
            PointType.Fault => "Fault",
            PointType.Winner => "Winner",
            PointType.UnforcedError => "Unforced error",
            PointType.ForcedError => "Forced error",
            PointType.Let => "Let",
            PointType.TimeViolation => "Time violation",
            _ => pointType.ToString()
        };

    private string GetPointClass(PointType pt)
        => pt switch
        {
            PointType.Ace => "btn-outline-success",
            PointType.Winner => "btn-outline-primary",
            PointType.ForcedError => "btn-outline-info",
            PointType.UnforcedError => "btn-outline-warning",
            PointType.DoubleFault => "btn-outline-danger",
            PointType.Fault => "btn-outline-secondary",
            PointType.Let => "btn-outline-secondary",
            PointType.TimeViolation => "btn-outline-dark",
            _ => "btn-outline-secondary"
        };

    private async Task AddPoint(Guid player, PointType pointType)
    {
        if (Match == null) return;

        var addPointRequest = new AddPointRequest
        {
            MatchId = Match.Id,
            WinnerId = player,
            PointType = pointType
        };

        // Add the point through the API
        await TennisApiClient.AddPointAsync(addPointRequest);

        // Refresh the match after SignalR propagation
        var updatedMatch = await TennisApiClient.MatchesGETAsync(Match.Id);
        Match = updatedMatch;
    }
    private void GoBack()
    {
        if (Match?.TournamentId != null)
            Navigation.NavigateTo($"/tournaments/{Match.TournamentId}");
        else
            Navigation.NavigateTo("/tournaments");
    }
}
