@page "/tournaments/create"
@using TennisScoreWebApp.Infrastructure.ExternalServices.TennisScoreApi
@inject ITennisApiClient TennisApiClient
@inject NavigationManager Navigation

<h1 class="text-2xl font-bold mb-4">Create New Tournament</h1>

<EditForm Model="@newTournament" OnValidSubmit="@HandleCreateTournament" FormName="CreateTournamentForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }

    <!-- Nom -->
    <div class="mb-3">
        <label class="form-label">Name</label>
        <InputText @bind-Value="newTournament.Name" class="form-control" />
    </div>

    <!-- Lieu -->
    <div class="mb-3">
        <label class="form-label">Location</label>
        <InputText @bind-Value="newTournament.Location" class="form-control" />
    </div>

    <!-- Dates -->
    <div class="mb-3">
        <label class="form-label">Start date</label>
        <InputDate @bind-Value="newTournament.StartDate" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">End date</label>
        <InputDate @bind-Value="newTournament.EndDate" class="form-control" />
    </div>

    <!-- Description -->
    <div class="mb-3">
        <label class="form-label">Description</label>
        <InputTextArea @bind-Value="newTournament.Description" class="form-control" />
    </div>

    <!-- Classement FFT -->
    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Minimum FFT ranking</label>
            <InputText @bind-Value="newTournament.MinRankingFft" class="form-control" />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Maximum FFT ranking</label>
            <InputText @bind-Value="newTournament.MaxRankingFft" class="form-control" />
        </div>
    </div>

    <!-- Âge -->
    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Minimum age</label>
            <InputNumber @bind-Value="newTournament.MinAge" class="form-control" />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Maximum age</label>
            <InputNumber @bind-Value="newTournament.MaxAge" class="form-control" />
        </div>
    </div>

    <!-- Catégories et types -->
    <div class="mb-3">
        <label class="form-label">Age category</label>
        <InputSelect @bind-Value="newTournament.AgeCategory" class="form-select">
            @foreach (var value in Enum.GetValues<AgeCategory>())
            {
                <option value="@value">@value</option>
            }
        </InputSelect>
    </div>

    <div class="mb-3">
        <label class="form-label">Type</label>
        <InputSelect @bind-Value="newTournament.Type" class="form-select">
            @foreach (var value in Enum.GetValues<TournamentType>())
            {
                <option value="@value">@value</option>
            }
        </InputSelect>
    </div>

    <div class="mb-3">
        <label class="form-label">Subtype</label>
        <InputSelect @bind-Value="newTournament.SubType" class="form-select">
            @foreach (var value in Enum.GetValues<TournamentSubType>())
            {
                <option value="@value">@value</option>
            }
        </InputSelect>
    </div>

    <!-- Niveau de balle -->
    <div class="mb-3">
        <label class="form-label">Ball level</label>
        <InputSelect @bind-Value="newTournament.BallLevel" class="form-select">
            @foreach (var value in Enum.GetValues<BallLevel>())
            {
                <option value="@value">@value</option>
            }
        </InputSelect>
    </div>

    <!-- Surface -->
    <div class="mb-3">
        <label class="form-label">Surface</label>
        <InputSelect @bind-Value="newTournament.Surface" class="form-select">
            @foreach (var value in Enum.GetValues<CourtSurface>())
            {
                <option value="@value">@value</option>
            }
        </InputSelect>
    </div>

    <!-- Conditions -->
    <div class="mb-3">
        <label class="form-label">Playing condition</label>
        <InputSelect @bind-Value="newTournament.Condition" class="form-select">
            @foreach (var value in Enum.GetValues<PlayingCondition>())
            {
                <option value="@value">@value</option>
            }
        </InputSelect>
    </div>

    <!-- Prize Money -->
    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Prize money</label>
            <InputNumber @bind-Value="newTournament.PrizeMoney" class="form-control" />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Currency</label>
            <InputText @bind-Value="newTournament.PrizeMoneyCurrency" class="form-control" />
        </div>
    </div>

    <!-- Format de match -->
    <div class="mb-3">
        <label class="form-label">Match format</label>
        <InputSelect @bind-Value="newTournament.MatchFormatId" class="form-select">
            <option value="0">Select a format</option>
            @foreach (var format in matchFormats)
            {
                <option value="@format.Id">@format.Name - @format.Application - @format.SetsToWin sets - @format.GamesPerSet games</option>
            }
        </InputSelect>
    </div>

    <button type="submit" class="btn btn-primary me-2">Create Tournament</button>
    <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
</EditForm>

@code {
    private CreateTournamentRequest newTournament = new()
    {
        StartDate = new DateTimeOffset(DateTime.Today),
        EndDate = new DateTimeOffset(DateTime.Today.AddDays(1)),
        PrizeMoneyCurrency = "EUR"
    };
    private List<MatchFormat> matchFormats = new();
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        matchFormats = (await TennisApiClient.MatchFormatsAllAsync()).ToList();
    }

    private async Task HandleCreateTournament()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(newTournament.Name))
        {
            errorMessage = "Tournament name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newTournament.Location))
        {
            errorMessage = "Tournament location is required.";
            return;
        }

        if (newTournament.EndDate < newTournament.StartDate)
        {
            errorMessage = "End date must be after start date.";
            return;
        }

        if (newTournament.MatchFormatId <= 0)
        {
            errorMessage = "Select a match format.";
            return;
        }

        await TennisApiClient.TournamentsPOSTAsync(newTournament);
        Navigation.NavigateTo("/tournaments");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/tournaments");
    }
}
